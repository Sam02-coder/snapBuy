# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Database (used directly by docker-compose; dev profile has localhost defaults) ---
DB_URL=jdbc:mysql://localhost:3306/ecommerce_db?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=root

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
# Generate a strong random value for production, e.g.: openssl rand -base64 48
JWT_SECRET=change-this-to-a-real-256-bit-secret-before-deploying

# --- Seeded admin account ---
ADMIN_EMAIL=admin@ecommerce.com
ADMIN_PASSWORD=Admin@12345

# --- Email (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# Use a Gmail App Password, not your real account password.
MAIL_PASSWORD=your-app-password

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173

# --- File uploads ---
UPLOAD_DIR=uploads
